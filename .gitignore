# Claude Code local settings
.claude/

# Editor / OS
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# Python (browser-print-shim.py is stdlib-only, but keep these for cleanliness)
__pycache__/
*.pyc
*.pyo

# Local config that may contain printer addresses
printers.json

# Local TLS material if anyone generates it for the shim's --https mode
*.pem
*.key

# zpl2pdf binaries (installed via install-zpl2pdf.sh; not committed)
/utils/bin/*/
!/utils/bin/.gitkeep

# Optional per-deployment override for the PDF feature key (see app/browser-print.html
# DEFAULT_FEATURE_KEY block). Falls back to the bundled public demo key if absent.
/app/feature-key.txt
